# ─── UnicornX Aleo Backend — Environment Variables ───
# Copy to `.env` (same directory) and fill in real values before `npm start`.
# `.env` is loaded by `dotenv` at the top of `server/config.js`.

# ─── Network / server ────────────────────────────────────────────────────
# HTTP port the Express app binds to. Nginx reverse-proxies to this.
PORT=5170

# Aleo network: "testnet" for development, "mainnet" once stable.
NETWORK=testnet

# Aleo explorer API. Same URL works for both testnet and mainnet —
# the `NETWORK` segment is injected by server/services/aleo.js.
ENDPOINT=https://api.explorer.provable.com/v1

# ─── Aleo program / admin identity ───────────────────────────────────────
# Deployed program name. Must match `contracts/unicornx_v3/program.json`.
PROGRAM_ID=unicornx_v3.aleo

# Admin Aleo private key — signs fulfill_open_pack, finalize_tournament,
# mint_initial_cards, etc. REQUIRED.
# Generate a fresh key for production:      leo account new
# Fund it on testnet:                        https://faucet.aleo.org
# Current admin address (testnet):           aleo1d96ex...   (rotate before mainnet)
ADMIN_PRIVATE_KEY=APrivateKey1zkpREPLACE_ME_WITH_REAL_KEY

# Aleo address that corresponds to ADMIN_PRIVATE_KEY above. REQUIRED.
# Only the owner of this address can call admin-only transitions on-chain.
ADMIN_ADDRESS=aleo1REPLACE_ME

# ─── Leo CLI ─────────────────────────────────────────────────────────────
# Path to the `leo` binary. Plain "leo" works if it is on $PATH (it usually
# lives at ~/.cargo/bin/leo after `cargo install leo-lang`).
LEO_PATH=leo

# Path (relative to server/) to the Leo project used for `leo execute`.
CONTRACT_PATH=../contracts/unicornx_v3

# ─── Admin HTTP auth ─────────────────────────────────────────────────────
# Shared secret required in `x-admin-key` header on /api/admin/* routes.
# Pick a long random string in production.
ADMIN_API_KEY=change-me

# ─── AI card recommender (OPTIONAL) ──────────────────────────────────────
# Used by server/services/ai-recommender.js. If unset, the recommender falls
# back to a heuristic scorer so the app still works.
# Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenRouter model used by the daily tweet scorer. `:free` models have zero
# cost but tight rate limits; paid models are more reliable at scale.
AI_SCORER_MODEL=google/gemma-3-4b-it:free

# ─── Twitter / X scoring (jobs/twitter-league-scorer.js) ─────────────────
# twitterapi.io API key — powers the daily tweet-collection cron.
# Sign up: https://twitterapi.io — the free tier is sufficient for ~20 handles/day.
# A working fallback key is baked into jobs/twitter-league-scorer.js, so this
# env var is OPTIONAL but STRONGLY recommended for production.
TWITTERAPI_IO_KEY=
